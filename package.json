{
  "name": "@docmgmt-ai/print-relay",
  "version": "0.0.0",
  "description": "On-prem print relay for docmgmt-ai over Cloudflare Tunnel",
  "private": true,
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run test/integration"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/ipp": "^2.0.5",
    "@types/node": "^20.19.39",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^8.57.1",
    "fast-check": "^3.23.2",
    "prettier": "^3.8.3",
    "supertest": "^6.3.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "helmet": "^7.2.0",
    "ipp": "^2.0.1",
    "pino": "^8.21.0",
    "pino-pretty": "^11.3.0",
    "zod": "^3.25.76"
  }
}
